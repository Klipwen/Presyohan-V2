<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Offset top and bottom negatively to hide the top/bottom stroke borders, leaving only the left/right curved ends -->
    <item
        android:top="-5dp"
        android:bottom="-5dp">
        <shape android:shape="rectangle">
            <solid android:color="#EAF6F8" />
            <stroke
                android:width="4.5dp"
                android:color="@color/presyo_teal" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>

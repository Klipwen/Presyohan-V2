<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_qr_screen">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Foreground White Container panel -->
        <View
            android:id="@+id/topCurve"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_curve_logo" />

        <!-- Circular Back Button -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/buttonBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_nav_icon_active"
            android:src="@drawable/icon_back"
            app:tint="@color/presyo_orange"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo_presyohan"
            android:layout_width="280dp"
            android:layout_height="220dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/splash_logo"
            android:scaleType="fitCenter"
            android:contentDescription="Presyohan Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Content Area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:layout_constraintTop_toBottomOf="@+id/logo_presyohan"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.3">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Verification Code"
                android:textColor="@color/presyo_orange"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- 6 boxes layout container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/layoutCodeBoxes"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="6">

                    <TextView
                        android:id="@+id/box1"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_margin="3dp"
                        android:background="@drawable/bg_code_box_empty"
                        android:gravity="center"
                        android:textColor="@color/presyo_darkblue"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/box2"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_margin="3dp"
                        android:background="@drawable/bg_code_box_empty"
                        android:gravity="center"
                        android:textColor="@color/presyo_darkblue"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/box3"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_margin="3dp"
                        android:background="@drawable/bg_code_box_empty"
                        android:gravity="center"
                        android:textColor="@color/presyo_darkblue"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/box4"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_margin="3dp"
                        android:background="@drawable/bg_code_box_empty"
                        android:gravity="center"
                        android:textColor="@color/presyo_darkblue"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/box5"
                        android:layout_width="0dp"
                        android:layout_height="63dp"
                        android:layout_weight="1"
                        android:layout_margin="3dp"
                        android:background="@drawable/bg_code_box_empty"
                        android:gravity="center"
                        android:textColor="@color/presyo_darkblue"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/box6"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:layout_margin="3dp"
                        android:background="@drawable/bg_code_box_empty"
                        android:gravity="center"
                        android:textColor="@color/presyo_darkblue"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Hidden Input overlay -->
                <EditText
                    android:id="@+id/hiddenCodeInput"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@android:color/transparent"
                    android:textColor="@android:color/transparent"
                    android:cursorVisible="false"
                    android:inputType="number"
                    android:maxLength="6"
                    android:textCursorDrawable="@null"
                    android:privateImeOptions="nm" />
            </FrameLayout>
            <!-- Description Message -->
            <TextView
                android:id="@+id/verifyMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We've sent you 6 digit Code to your email"
                android:textColor="@color/edittext_hint"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="2dp" />

            <!-- Email Display (Dynamic, bold orange) -->
            <TextView
                android:id="@+id/verifyEmailDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/presyo_orange"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                tools:text="caliphjuen@gmail.com" />

            <!-- Hidden/Unused Feedback Message to maintain code compatibility -->
            <TextView
                android:id="@+id/feedbackMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Resend Container (directly above action button to match design) -->
        <LinearLayout
            android:id="@+id/resendContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp"
            app:layout_constraintBottom_toTopOf="@+id/buttonVerifyCode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Did'nt get the code? "
                android:textColor="@color/presyo_darkblue"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textResendCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resend Code"
                android:textColor="@color/presyo_teal"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Verify Code Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/buttonVerifyCode"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:background="@drawable/button_round"
            android:backgroundTint="@color/presyo_orange"
            android:text="Verify Code"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="72dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</RelativeLayout>

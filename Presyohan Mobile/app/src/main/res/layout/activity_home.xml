<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:fitsSystemWindows="true">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E5E5E5">

            <!-- Curved Header Container -->
            <LinearLayout
                android:id="@+id/curvedHeaderContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_category_filter"
                android:orientation="vertical"
                android:elevation="6dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Part 1: Menu & Logo Header -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/headerPresyohan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <ImageView
                        android:id="@+id/menuIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="16dp"
                        android:contentDescription="Menu"
                        android:src="@drawable/icon_menu"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/logoText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="sans-serif"
                        android:text="presyo"
                        android:textColor="@color/presyo_orange"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/menuIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/logoTextBlue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="0dp"
                        android:fontFamily="sans-serif"
                        android:text="han?"
                        android:textColor="@color/presyo_teal"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/logoText"
                        app:layout_constraintTop_toTopOf="@id/logoText"
                        app:layout_constraintBottom_toBottomOf="@id/logoText" />

                     <ImageView
                        android:id="@+id/notifIcon"
                        android:layout_width="24dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="Notifications"
                        android:src="@drawable/icon_notification"
                        app:layout_constraintEnd_toStartOf="@id/profileIconContainer"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <View
                        android:id="@+id/notifDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/indicator_dot"
                        android:visibility="gone"
                        app:layout_constraintEnd_toStartOf="@id/profileIconContainer"
                        app:layout_constraintTop_toTopOf="parent" />

                    <FrameLayout
                        android:id="@+id/profileIconContainer"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_avatar_border"
                        android:padding="2dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <ImageView
                            android:id="@+id/profileIcon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:contentDescription="Profile"
                            android:src="@drawable/avatar_default" />
                    </FrameLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Store Banner Header -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/imgHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_header_yellow"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_back"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white" />

                    <ImageView
                        android:id="@+id/iconStoreSmall"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="12dp"
                        android:src="@drawable/icon_store"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/btnBack"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btnStoreOptions"
                        app:layout_constraintStart_toEndOf="@id/iconStoreSmall"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/textStoreName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Store"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btnStoreOptions"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/icon_options"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/white" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Control Bar (PRICELIST Label Trigger) -->
                <RelativeLayout
                    android:id="@+id/containerControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <Spinner
                        android:id="@+id/categorySpinner"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_alignParentTop="true" />

                    <LinearLayout
                        android:id="@+id/layoutPricelistTrigger"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_centerHorizontal="true"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingHorizontal="8dp">

                        <TextView
                            android:id="@+id/categoryLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text="PRICELIST"
                            android:textColor="@color/presyo_orange"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/categoryDrawerButton"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/icon_category_drawer"
                            app:tint="@color/presyo_orange" />
                    </LinearLayout>

                </RelativeLayout>

            </LinearLayout>

            <!-- Pull-to-refresh container -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefreshLayout"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/curvedHeaderContainer"
                tools:ignore="MissingClass">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Main Recycler (shows parent Category Cards) -->

                    <!-- Empty State Container -->

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/productRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingTop="8dp"
                        android:paddingBottom="140dp" />

                    <LinearLayout
                        android:id="@+id/layoutEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/imageEmptyState"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/icon_search"
                            app:tint="#888888"
                            android:contentDescription="Empty state icon" />

                        <TextView
                            android:id="@+id/textEmptyStateTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No Items Found"
                            android:textColor="#888888"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="16dp"/>

                    </LinearLayout>

                </FrameLayout>
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <!-- Loading Shimmer Skeleton Container -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerContainer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:shimmer_auto_start="true"
                app:shimmer_base_alpha="0.4"
                app:shimmer_highlight_alpha="1.0"
                app:shimmer_duration="1200"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/curvedHeaderContainer"
                tools:ignore="MissingClass">

                <include layout="@layout/layout_home_shimmer" />

            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- Floating Search/Trigger FAB Button -->
            <ImageButton
                android:id="@+id/searchItemButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="32dp"
                android:background="@android:color/transparent"
                android:elevation="24dp"
                android:scaleType="fitCenter"
                android:src="@drawable/button_search_item"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Docked Bottom Sheet Container -->
        <LinearLayout
            android:id="@+id/bottomSheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_sheet"
            android:padding="16dp"
            android:elevation="24dp"
            android:outlineAmbientShadowColor="#000000"
            android:outlineSpotShadowColor="#000000"
            android:outlineProvider="background"
            app:behavior_hideable="true"
            app:behavior_peekHeight="114dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">


            <!-- Sheet Handle -->
            <View
                android:id="@+id/bottomSheetHandle"
                android:layout_width="98dp"
                android:layout_height="5dp"
                android:background="@color/presyo_yellow"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp" />

            <!-- Search input container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_edittext"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/icon_search"
                    app:tint="#888888"
                    android:contentDescription="Search Icon" />

                <EditText
                    android:id="@+id/bottomSearchEditText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search item..."
                    android:paddingStart="8dp"
                    android:textColor="@color/presyo_darkblue"
                    android:textColorHint="@color/edittext_hint"
                    android:textSize="14sp"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/btnSearchClear"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_close_gray"
                    android:padding="4dp"
                    android:visibility="gone"
                    android:contentDescription="Clear Search" />

            </LinearLayout>

            <!-- Quick actions row for Owners/Managers -->
            <LinearLayout
                android:id="@+id/layoutSheetActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:weightSum="3"
                android:visibility="gone">

                <!-- Manage Prices -->
                <LinearLayout
                    android:id="@+id/btnManagePrices"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="80dp">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:src="@drawable/icon_pricelist"
                            android:background="@drawable/bg_rounded_cream_box"
                            android:padding="14dp"
                            android:scaleType="fitCenter"
                            android:contentDescription="Manage Prices"
                            app:tint="@color/presyo_orange" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Prices"
                        android:textColor="@color/presyo_orange"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Center Add Item Button -->
                <LinearLayout
                    android:id="@+id/btnSheetAddItem"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp">
                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center"
                            android:src="@drawable/icon_add_item"
                            android:contentDescription="Add Item"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Item"
                        android:textColor="@color/presyo_orange"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Manage Categories -->
                <LinearLayout
                    android:id="@+id/btnManageCategories"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="80dp">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center"
                            android:src="@drawable/icon_category"
                            android:background="@drawable/bg_rounded_cream_box"
                            android:padding="14dp"
                            android:scaleType="fitCenter"
                            android:contentDescription="Manage Categories"
                            app:tint="@color/presyo_orange" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Categories"
                        android:textColor="@color/presyo_orange"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer -->
    <include layout="@layout/layout_custom_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinatorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white">

            <!-- Dummy views to keep existing Kotlin code compile-safe until refactored -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/buttonDone"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/itemCounter"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- ==================== NORMAL MODE HEADER CONTAINER ==================== -->
            <LinearLayout
                android:id="@+id/layoutNormalHeaderContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- ==================== NORMAL MODE HEADER ==================== -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutNormalHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:paddingBottom="10dp"
                    android:elevation="2dp"
                    android:visibility="visible">

                    <!-- Yellow Header Label inside the White Header -->
                    <TextView
                        android:id="@+id/headerLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_header_yellow"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:text="Manage Items"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:layout_editor_absoluteX="8dp" />

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_back"
                        android:layout_marginStart="16dp"
                        app:layout_constraintBottom_toBottomOf="@+id/headerLabel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/headerLabel"
                        app:tint="@color/white" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ==================== NORMAL MODE: CATEGORY BAR ==================== -->
                <LinearLayout
                    android:id="@+id/layoutCategoryBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp"
                    android:paddingTop="8dp"
                    android:paddingHorizontal="12dp"
                    android:visibility="visible">

                    <!-- Category Selector Trigger -->
                    <LinearLayout
                        android:id="@+id/layoutCategoryTrigger"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/categoryLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRICELIST"
                            android:textColor="@color/presyo_orange"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textAllCaps="true" />

                        <!-- Hidden Spinner for category selection -->
                        <Spinner
                            android:id="@+id/categorySpinner"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />

                        <ImageView
                            android:id="@+id/categoryDrawerButton"
                            android:layout_width="12dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/icon_store_dropdown"
                            app:tint="@color/presyo_orange"
                            android:contentDescription="Category Dropdown" />
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- General Add Item Button (Only shown in PRICELIST state, Normal Mode) -->
                    <ImageButton
                        android:id="@+id/btnAddItemGeneral"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/button_round"
                        android:src="@drawable/icon_add_item"
                        android:scaleType="fitCenter"
                        android:contentDescription="Add Item"
                        android:visibility="visible" />

                    <!-- Manage Category Button (Normal Mode) -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnManageCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:backgroundTint="@color/presyo_teal"
                        android:text="Manage Category"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:visibility="visible" />

                    <!-- Selection Mode Tools (Selection Mode) -->
                    <LinearLayout
                        android:id="@+id/layoutSelectionActions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <!-- Publish / Unpublish -->
                        <LinearLayout
                            android:id="@+id/btnBulkPublish"
                            android:layout_width="56dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:id="@+id/iconBulkPublish"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/icon_globe"
                                app:tint="@color/presyo_orange"
                                android:contentDescription="Bulk Publish" />

                            <TextView
                                android:id="@+id/textBulkPublish"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Publish"
                                android:textColor="@color/presyo_orange"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Copy -->
                        <LinearLayout
                            android:id="@+id/btnBulkCopy"
                            android:layout_width="56dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/icon_copy_prices"
                                app:tint="@color/presyo_orange"
                                android:contentDescription="Bulk Copy" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Copy"
                                android:textColor="@color/presyo_orange"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Convert -->
                        <LinearLayout
                            android:id="@+id/btnBulkConvert"
                            android:layout_width="56dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/icon_convert"
                                app:tint="@color/presyo_orange"
                                android:contentDescription="Bulk Convert" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Convert"
                                android:textColor="@color/presyo_orange"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Delete -->
                        <LinearLayout
                            android:id="@+id/btnBulkDelete"
                            android:layout_width="56dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/icon_delete"
                                app:tint="@color/presyo_orange"
                                android:contentDescription="Bulk Delete" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Delete"
                                android:textColor="@color/presyo_orange"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ==================== NORMAL MODE: SUMMARY ROW ==================== -->
                <RelativeLayout
                    android:id="@+id/layoutSummaryRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:background="@drawable/bg_summary_box_grey"
                    android:paddingVertical="12dp"
                    android:visibility="visible">

                    <!-- Normal Mode Content -->
                    <LinearLayout
                        android:id="@+id/layoutSummaryNormalContent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/btnSelectMode"
                        android:visibility="visible">

                        <!-- Title text: e.g. "2 Categories and 54 Public Items" -->
                        <TextView
                            android:id="@+id/textSummaryTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Categories and 0 total items"
                            android:textColor="#4A4A4A"
                            android:textStyle="bold"
                            android:textSize="14sp" />

                        <!-- Subtitle row: e.g. "102 total items. View All" -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="2dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/textSummarySubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 total items."
                                android:textColor="#888888"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/btnViewPublicItems"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="View All"
                                android:textColor="@color/presyo_teal"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Select Button (Normal Mode) -->
                    <TextView
                        android:id="@+id/btnSelectMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Select"
                        android:textColor="@color/presyo_teal"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="visible" />

                    <!-- Selection Mode Content -->
                    <LinearLayout
                        android:id="@+id/layoutSummarySelectionContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <!-- Selection count text on the left -->
                        <TextView
                            android:id="@+id/textSelectionCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0 Categories and 0 items selected"
                            android:textColor="#4A4A4A"
                            android:textStyle="bold"
                            android:textSize="10sp" />

                        <!-- Select all / Cancel links on the right -->
                        <TextView
                            android:id="@+id/btnSelectAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select all"
                            android:textColor="@color/presyo_teal"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnCancelSelection"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Cancel"
                            android:textColor="@color/presyo_orange"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>

            <!-- ==================== HEADER BARRIER ==================== -->
            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/headerBarrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="layoutNormalHeaderContainer" />

            <!-- ==================== MAIN RECYCLER VIEW ==================== -->

            <!-- ==================== SEARCH FLOATING BUTTON (FAB) ==================== -->
            <!-- Pull-to-refresh container -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefreshLayout"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerBarrier"
                tools:ignore="MissingClass">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewItems"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/light_gray"
                        android:clipToPadding="false"
                        android:paddingTop="4dp"
                        android:paddingBottom="140dp" />

                </FrameLayout>
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <!-- Loading Shimmer Skeleton Container -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerContainer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:shimmer_auto_start="true"
                app:shimmer_base_alpha="0.4"
                app:shimmer_highlight_alpha="1.0"
                app:shimmer_duration="1200"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerBarrier"
                tools:ignore="MissingClass">

                <include layout="@layout/layout_items_shimmer" />

            </com.facebook.shimmer.ShimmerFrameLayout>

            <ImageButton
                android:id="@+id/fabSearch"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="32dp"
                android:background="@android:color/transparent"
                android:elevation="24dp"
                android:scaleType="fitCenter"
                android:src="@drawable/button_search_item"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:contentDescription="Search Item" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Docked Bottom Sheet Container -->
        <LinearLayout
            android:id="@+id/bottomSheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_sheet"
            android:padding="16dp"
            android:elevation="24dp"
            android:outlineAmbientShadowColor="#000000"
            android:outlineSpotShadowColor="#000000"
            android:outlineProvider="background"
            app:behavior_hideable="true"
            app:behavior_peekHeight="114dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

            <!-- Search input container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_edittext"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/icon_search"
                    app:tint="#888888"
                    android:contentDescription="Search Icon" />

                <EditText
                    android:id="@+id/bottomSearchEditText"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search item..."
                    android:paddingStart="8dp"
                    android:textColor="@color/presyo_darkblue"
                    android:textColorHint="@color/edittext_hint"
                    android:textSize="14sp"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/btnSearchClear"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_close_gray"
                    android:padding="4dp"
                    android:visibility="gone"
                    android:contentDescription="Clear Search" />
            </LinearLayout>
        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</androidx.drawerlayout.widget.DrawerLayout>
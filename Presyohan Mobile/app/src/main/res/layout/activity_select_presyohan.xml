<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E5E5E5"
    android:fitsSystemWindows="false">

    <!-- Curved Header Container -->
    <LinearLayout
        android:id="@+id/curvedHeaderContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_category_filter"
        android:orientation="vertical"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Part 2: Select Header Area -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/selectHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <!-- Back Button (Circular) -->
            <FrameLayout
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_rounded_cream_box"
                android:backgroundTint="#FDF2E9"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/icon_back"
                    app:tint="@color/presyo_orange"
                    android:contentDescription="Go Back" />
            </FrameLayout>

            <!-- Title and Subtitle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintEnd_toStartOf="@id/btnInfo"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Presyohan"
                    android:textColor="@color/presyo_orange"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online Based Prices 2026"
                    android:textColor="#94A3B8"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Info Button (Circular) -->
            <FrameLayout
                android:id="@+id/btnInfo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/icon_info"
                    app:tint="@color/presyo_teal"
                    android:contentDescription="Info" />
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Part 3: Search input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutSearch"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearchPresyohan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_customer_search_input"
                android:hint="Search presyohan..."
                android:textColorHint="#94A3B8"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:inputType="text"
                android:singleLine="true"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Store List RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPresyohanStores"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/curvedHeaderContainer"
        app:layout_constraintBottom_toTopOf="@id/bottomBar" />

    <!-- Loading Shimmer / Indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/presyo_orange"
        app:layout_constraintTop_toTopOf="@id/rvPresyohanStores"
        app:layout_constraintBottom_toBottomOf="@id/rvPresyohanStores"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty State View -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvPresyohanStores"
        app:layout_constraintBottom_toBottomOf="@id/rvPresyohanStores"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/icon_sad_robot" />

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No available Presyohan stores found."
            android:textColor="#64748B"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Bottom Action Button Panel -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:padding="20dp"
        android:elevation="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Add Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAddPresyohan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_add_selector"
            android:text="ADD TO YOUR STORE LIST"
            android:textColor="@color/selector_button_add_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:enabled="false" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

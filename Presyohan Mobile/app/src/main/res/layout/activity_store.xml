<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:background="#F4F6F9">

        <!-- Curved Header Container -->
        <LinearLayout
            android:id="@+id/curvedHeaderContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_category_filter"
            android:orientation="vertical"
            android:elevation="6dp"
            android:paddingBottom="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Part 1: Menu & Logo Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerPresyohan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/menuIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="16dp"
                    android:contentDescription="Menu"
                    android:src="@drawable/icon_menu"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Logo -->
                <TextView
                    android:id="@+id/logoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="sans-serif"
                    android:text="presyo"
                    android:textColor="@color/presyo_orange"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/menuIcon"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/logoTextBlue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="han?"
                    android:textColor="@color/presyo_teal"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/logoText"
                    app:layout_constraintStart_toEndOf="@id/logoText"
                    app:layout_constraintTop_toTopOf="@id/logoText" />

                <!-- Notifications -->
                <ImageView
                    android:id="@+id/notifIcon"
                     android:layout_width="24dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="Notifications"
                    android:src="@drawable/icon_notification"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/profileIconContainer"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/notifDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/indicator_dot"
                    android:visibility="gone"
                    app:layout_constraintEnd_toStartOf="@id/profileIconContainer"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Profile -->
                <FrameLayout
                    android:id="@+id/profileIconContainer"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_avatar_border"
                    android:padding="2dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/profileIcon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Profile"
                        android:src="@drawable/avatar_default" />
                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Store Banner Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/imgHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_header_yellow"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <TextView
                    android:id="@+id/textStoresTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stores"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Part 3: Search Input Box -->
            <RelativeLayout
                android:id="@+id/searchBarLayout"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_search_input"
                android:paddingHorizontal="12dp">

                <EditText
                    android:id="@+id/searchStoreEditText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="-346dp"
                    android:layout_marginStart="12dp"
                    android:layout_toStartOf="@+id/btnSearchClear"
                    android:background="@android:color/transparent"
                    android:hint="Search store"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/black"
                    android:textColorHint="@color/edittext_hint"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/btnSearchClear"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_toStartOf="@+id/searchIconRight"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Clear Text"
                    android:src="@drawable/ic_close_gray"
                    android:visibility="gone"
                    app:tint="@color/edittext_hint" />

                <ImageView
                    android:id="@+id/searchIconRight"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="Search Icon"
                    android:src="@drawable/icon_search"
                    app:tint="@color/edittext_hint" />
            </RelativeLayout>

            <!-- Part 4: Filter Tabs (Segmented Control Layout with sliding indicator) -->
            <FrameLayout
                android:id="@+id/tabContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_segmented_control"
                android:padding="3dp">

                <!-- Sliding Selection Indicator View -->
                <View
                    android:id="@+id/tabIndicator"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_segmented_tab_selected" />

                <!-- Text Tabs Container -->
                <LinearLayout
                    android:id="@+id/tabsLinearLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Tab: All -->
                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:text="All"
                        android:textColor="@color/presyo_orange"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Tab: Owner -->
                    <TextView
                        android:id="@+id/chipOwner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:text="Owner"
                        android:textColor="@color/edittext_hint"
                        android:textSize="14sp" />

                    <!-- Tab: Manager -->
                    <TextView
                        android:id="@+id/chipManager"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:text="Manager"
                        android:textColor="@color/edittext_hint"
                        android:textSize="14sp" />

                    <!-- Tab: Sales staff -->
                    <TextView
                        android:id="@+id/chipStaff"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingVertical="8dp"
                        android:text="Sales staff"
                        android:textColor="@color/edittext_hint"
                        android:textSize="14sp" />

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- Pull to Refresh surrounding List -->

        <!-- Shimmer loading state (overlapping list) -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshLayout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/curvedHeaderContainer"
            app:layout_constraintVertical_bias="0.0">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewStores"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="140dp" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/curvedHeaderContainer">

            <include layout="@layout/layout_store_shimmer" />
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- Empty State Layout -->
        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/curvedHeaderContainer">

            <ImageView
                android:id="@+id/emptyStateIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:contentDescription="Empty Icon"
                android:src="@drawable/icon_store"
                app:tint="@color/edittext_hint" />

            <TextView
                android:id="@+id/emptyStateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No stores found"
                android:textColor="@color/edittext_hint"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Legacy No Store Label (Fallback, hidden by default) -->
        <TextView
            android:id="@+id/noStoreLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="No Store"
            android:textColor="@android:color/darker_gray"
            android:textSize="18sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/curvedHeaderContainer" />

        <!-- Floating Add Store Button -->
        <ImageButton
            android:id="@+id/addStoreButton"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="Add Store"
            android:elevation="24dp"
            android:scaleType="fitCenter"
            android:src="@drawable/button_add_store"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Dimmed Background Overlay (For Bottom Sheet) -->
        <View
            android:id="@+id/dimmedBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:visibility="gone"
            android:elevation="30dp" />

        <!-- Add Store Bottom Sheet Container -->
        <LinearLayout
            android:id="@+id/addStoreBottomSheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_sheet"
            android:paddingTop="18dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="16dp"
            android:elevation="32dp"
            android:outlineAmbientShadowColor="#000000"
            android:outlineSpotShadowColor="#000000"
            android:outlineProvider="background"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Store"
                android:textColor="@color/presyo_orange"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <!-- Button 1: Join Store -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBottomSheetJoinStore"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_round_teal_pill"
                android:text="JOIN STORE"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Button 2: Create Store -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBottomSheetCreateStore"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_round_orange_pill"
                android:text="CREATE STORE"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Side Navigation Menu Drawer -->
    <include layout="@layout/layout_custom_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_rounded"
    android:layout_margin="16dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select or Add Category"
        android:textColor="@color/presyo_orange"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <AutoCompleteTextView
        android:id="@+id/inputCategoryName"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:hint="Type or select category..."
        android:paddingHorizontal="12dp"
        android:textSize="14sp"
        android:background="@drawable/bg_edittext"
        android:textColor="@color/presyo_darkblue"
        android:textColorHint="@color/edittext_hint"
        android:inputType="textCapCharacters"
        android:completionThreshold="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelAddCategory"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="@color/white"
            android:backgroundTint="@color/presyo_teal"
            app:cornerRadius="8dp"
            android:layout_marginEnd="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmAddCategory"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Add"
            android:textColor="@color/white"
            android:backgroundTint="@color/presyo_orange"
            app:cornerRadius="8dp"
            android:layout_marginStart="6dp" />

    </LinearLayout>

</LinearLayout>
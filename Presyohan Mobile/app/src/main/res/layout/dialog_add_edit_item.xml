<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog1"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <!-- Dialog Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_header_yellow"
        android:paddingVertical="8dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/icon_back"
            app:tint="@color/white"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Edit Item"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Store Info and Action Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:layout_marginHorizontal="4dp">

                <LinearLayout
                    android:id="@+id/storeInfoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/btnTopAction"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/dialogStoreText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Store Name"
                        android:textColor="@color/presyo_orange"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/dialogStoreBranchText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Branch name"
                        android:textColor="@color/edittext_hint"
                        android:textSize="13sp" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnTopAction"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/presyo_teal"
                    android:text="Manage Items"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textAllCaps="false"
                    android:paddingHorizontal="12dp" />

            </RelativeLayout>

            <!-- Form Cards Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_unselected"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Item Name Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutItemName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="@color/stroke_orange"
                    app:hintTextColor="@color/presyo_orange"
                    android:textColorHint="@color/presyo_orange"
                    app:expandedHintEnabled="false"
                    app:boxCornerRadiusTopStart="24dp"
                    app:boxCornerRadiusTopEnd="24dp"
                    app:boxCornerRadiusBottomStart="24dp"
                    app:boxCornerRadiusBottomEnd="24dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputItemName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:hint="Item name"
                        android:textColor="@color/presyo_darkblue"
                        android:textSize="15sp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="16dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Item Description Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutItemDescription"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxStrokeColor="@color/stroke_teal"
                    app:hintTextColor="@color/presyo_teal"
                    android:textColorHint="@color/presyo_teal"
                    app:expandedHintEnabled="false"
                    app:boxCornerRadiusTopStart="24dp"
                    app:boxCornerRadiusTopEnd="24dp"
                    app:boxCornerRadiusBottomStart="24dp"
                    app:boxCornerRadiusBottomEnd="24dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputItemDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:maxLines="4"
                        android:hint="Item description"
                        android:textColor="@color/presyo_darkblue"
                        android:textSize="15sp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="16dp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Category Spinner/Dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutItemCategory"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:textColorHint="@color/presyo_teal"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="@color/stroke_teal"
                    app:expandedHintEnabled="false"
                    app:hintTextColor="@color/presyo_teal">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerItemCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Category"
                        android:inputType="none"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:textColor="@color/presyo_teal"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Price and Unit Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:weightSum="2">

                    <!-- Price Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutItemPrice"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.1"
                        android:layout_marginEnd="6dp"
                        app:boxStrokeColor="@color/stroke_teal"
                        app:hintTextColor="@color/presyo_teal"
                        android:textColorHint="@color/presyo_teal"
                        app:expandedHintEnabled="false"
                        app:prefixText="₱ | "
                        app:prefixTextColor="@color/presyo_darkblue"
                        app:boxCornerRadiusTopStart="24dp"
                        app:boxCornerRadiusTopEnd="24dp"
                        app:boxCornerRadiusBottomStart="24dp"
                        app:boxCornerRadiusBottomEnd="24dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputItemPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:hint="Price"
                            android:textColor="#757575"
                            android:textSize="15sp"
                            android:paddingVertical="10dp"
                            android:paddingHorizontal="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Unit Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutItemUnit"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.9"
                        android:layout_marginStart="6dp"
                        app:boxStrokeColor="@color/stroke_teal"
                        app:hintTextColor="@color/presyo_teal"
                        android:textColorHint="@color/presyo_teal"
                        app:expandedHintEnabled="false"
                        app:boxCornerRadiusTopStart="24dp"
                        app:boxCornerRadiusTopEnd="24dp"
                        app:boxCornerRadiusBottomStart="24dp"
                        app:boxCornerRadiusBottomEnd="24dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputItemUnit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:hint="Unit"
                            android:textColor="@color/presyo_darkblue"
                            android:textSize="15sp"
                            android:paddingVertical="10dp"
                            android:paddingHorizontal="16dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Make it Public Checkbox -->
                <CheckBox
                    android:id="@+id/cbMakePublic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="4dp"
                    android:button="@null"
                    android:drawableStart="@drawable/selector_public_checkbox"
                    android:drawablePadding="10dp"
                    android:text="Make it Public"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:gravity="center_vertical" />

            </LinearLayout>

            <!-- Done Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/buttonDone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/button_round"
                android:backgroundTint="@color/presyo_orange"
                android:text="DONE"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>

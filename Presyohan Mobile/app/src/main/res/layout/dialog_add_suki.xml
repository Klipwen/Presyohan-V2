<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_custom"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add your Suking Tindahan"
        android:textColor="@color/presyo_orange"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Store Card Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardStoreInfo"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_rounded_grey"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvDialogTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Default State View (Store Icon centered) -->
        <ImageView
            android:id="@+id/ivStoreDefaultIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/icon_store"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Resolved State View: Store Icon Left -->
        <ImageView
            android:id="@+id/ivStoreIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/icon_store"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Private Badge -->
        <TextView
            android:id="@+id/tvPrivateBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Private"
            android:textColor="#64748B"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_grey"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Resolved State View: Store Info Details -->
        <LinearLayout
            android:id="@+id/layoutStoreInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivStoreIcon"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvStoreName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Store Name"
                android:textColor="@color/presyo_orange"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStoreType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="General Merchandise"
                android:textColor="@color/presyo_teal"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/icon_branch"
                    app:tint="#94A3B8" />

                <TextView
                    android:id="@+id/tvStoreBranch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location branch"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Input Row (Text Input Container + Scan QR Button) -->
    <LinearLayout
        android:id="@+id/layoutInputRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/cardStoreInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Material Outlined Input Box -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutStoreId"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:boxStrokeColor="@color/stroke_orange"
            app:hintTextColor="@color/presyo_orange"
            android:textColorHint="@color/presyo_orange"
            app:expandedHintEnabled="false"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStoreId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters"
                android:singleLine="true"
                android:hint="Store ID"
                android:textColor="#757575"
                android:textSize="15sp"
                android:paddingVertical="10dp"
                android:paddingHorizontal="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Enter Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogEnter"
            android:layout_width="86dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_button_enter_selector"
            android:text="Enter"
            android:textColor="@color/selector_button_add_text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:enabled="false" />

        <!-- Scan QR Icon Button -->
        <ImageView
            android:id="@+id/btnDialogScanQr"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/icon_take_photo_on_qr"
            app:tint="@color/presyo_orange"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Scan QR" />

    </LinearLayout>

    <!-- Bottom Actions Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutInputRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogBack"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="BACK"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_round_teal_pill" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDialogAdd"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="ADD"
            android:textColor="@color/selector_button_add_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:enabled="false"
            android:background="@drawable/bg_button_add_selector" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_custom"
    android:padding="24dp">

    <!-- Top Right Close Icon (visible in error state) -->
    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="10dp"
        android:src="@drawable/ic_close_gray"
        android:visibility="gone"
        android:contentDescription="Close" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="24dp"
            android:gravity="center"
            android:text="I'm parsing your list, please wait..."
            android:textColor="@color/presyo_orange"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Center Mascot & Loader Container -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp">

            <!-- Progress Loader (visible in loading state) -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressIndicator"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                app:indicatorColor="@color/presyo_teal"
                app:trackColor="@android:color/transparent"
                app:trackThickness="8dp"
                app:indicatorSize="140dp"
                android:indeterminate="true" />

            <!-- Robot Mascot -->
            <ImageView
                android:id="@+id/imgMascot"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/icon_happy_robot"
                android:contentDescription="Mascot" />

        </FrameLayout>

        <!-- Subtitle/Message -->
        <TextView
            android:id="@+id/dialogSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="Reading your list... this may take a moment."
            android:textColor="@color/edittext_hint"
            android:textSize="14sp" />

        <!-- Loading Mode Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:text="CANCEL"
            android:textColor="@color/white"
            android:backgroundTint="@color/presyo_teal"
            android:textStyle="bold"
            android:textSize="16sp"
            app:cornerRadius="24dp"
            android:visibility="visible" />

        <!-- Error Mode Stacked Buttons Container -->
        <LinearLayout
            android:id="@+id/layoutErrorButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Retry Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetry"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="8dp"
                android:text="RETRY"
                android:textColor="@color/white"
                android:backgroundTint="@color/presyo_teal"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="24dp" />

            <!-- Use Built-in Parser Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUseBuiltIn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="12dp"
                android:text="USE BUILT-IN PARSER"
                android:textColor="@color/white"
                android:backgroundTint="@color/presyo_orange"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="24dp" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog1"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <!-- Dialog Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_header_yellow"
        android:paddingVertical="8dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/icon_back"
            app:tint="@color/white"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Edit Store"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="16dp">

            <!-- Store Icon -->
            <ImageView
                android:id="@+id/imgStoreIcon"
                android:layout_width="120dp"
                android:layout_height="100dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/icon_store"
                android:contentDescription="Store Icon" />

            <!-- Store Name Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutStoreName"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="@color/stroke_orange"
                app:hintTextColor="@color/presyo_orange"
                android:textColorHint="@color/presyo_orange"
                app:expandedHintEnabled="false"
                app:boxCornerRadiusTopStart="24dp"
                app:boxCornerRadiusTopEnd="24dp"
                app:boxCornerRadiusBottomStart="24dp"
                app:boxCornerRadiusBottomEnd="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputStoreName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:hint="Store name"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Store Branch Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutStoreBranch"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:boxStrokeColor="@color/stroke_teal"
                app:hintTextColor="@color/presyo_teal"
                android:textColorHint="@color/presyo_teal"
                app:expandedHintEnabled="false"
                app:boxCornerRadiusTopStart="24dp"
                app:boxCornerRadiusTopEnd="24dp"
                app:boxCornerRadiusBottomStart="24dp"
                app:boxCornerRadiusBottomEnd="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputStoreBranch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:hint="Store branch"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Store Type Dropdown (Rounded Rectangle) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutStoreType"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:textColorHint="@color/presyo_teal"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/stroke_teal"
                app:expandedHintEnabled="false"
                app:hintTextColor="@color/presyo_teal">

                <AutoCompleteTextView
                    android:id="@+id/spinnerStoreType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Store type"
                    android:inputType="none"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:textColor="@color/presyo_teal"
                    android:textSize="15sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Specific Store Type Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutSpecificStoreType"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:boxStrokeColor="@color/stroke_teal"
                app:hintTextColor="@color/presyo_teal"
                android:textColorHint="@color/presyo_teal"
                app:expandedHintEnabled="false"
                app:boxCornerRadiusTopStart="24dp"
                app:boxCornerRadiusTopEnd="24dp"
                app:boxCornerRadiusBottomStart="24dp"
                app:boxCornerRadiusBottomEnd="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputSpecificStoreType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:hint="Specific store type"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="15sp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Done Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/buttonDone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/button_round_orange"
                android:text="DONE"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog1">

        <!-- Dialog Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_header_yellow"
            android:paddingVertical="8dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@drawable/icon_back"
                app:tint="@color/white"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Import Prices"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Scrollable Content with padding bottom to prevent clipping/cropping when NEXT is GONE -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="24dp">

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Choose an import method"
                    android:textColor="@color/presyo_teal"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Options Cards Container -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <!-- Excel Option Card -->
                    <LinearLayout
                        android:id="@+id/cardExcelOption"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_card_unselected_teal"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgExcelRadio"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_radio_unchecked" />

                        <TextView
                            android:id="@+id/tvExcelLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Import Excel File"
                            android:textColor="@color/presyo_teal"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Paste Option Card -->
                    <LinearLayout
                        android:id="@+id/cardPasteOption"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_card_unselected_teal"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgPasteRadio"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_radio_unchecked" />

                        <TextView
                            android:id="@+id/tvPasteLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Paste raw text"
                            android:textColor="@color/presyo_teal"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Dynamic Content Panel -->
                <FrameLayout
                    android:id="@+id/dynamicPanelContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <!-- Excel Content -->
                    <LinearLayout
                        android:id="@+id/panelExcel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/bg_rounded_grey"
                        android:padding="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload your pricelist file"
                            android:textColor="@color/presyo_darkblue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSelectExcelFile"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose .xlsx"
                            android:textColor="@color/presyo_teal"
                            app:strokeColor="@color/presyo_teal"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            app:cornerRadius="6dp" />

                        <LinearLayout
                            android:id="@+id/layoutSelectedFile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="12dp"
                            android:visibility="gone">

                            <ImageView
                                android:id="@+id/btnClearSelectedFile"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/icon_delete"
                                app:tint="@color/red" />

                            <TextView
                                android:id="@+id/tvSelectedFile"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Selected: filename.xlsx"
                                android:textColor="@color/edittext_hint"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Paste Content -->
                    <LinearLayout
                        android:id="@+id/panelPaste"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paste your pricelist here:"
                            android:textColor="@color/edittext_hint"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp" />

                        <!-- Format Guide Block -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_rounded_grey"
                            android:padding="8dp"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Valid format:"
                                android:textColor="@color/edittext_hint"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Category\n  - Item name (descriptions) - P99,999.00 | unit"
                                android:textColor="@color/edittext_hint"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"
                                android:fontFamily="monospace" />

                        </LinearLayout>

                        <EditText
                            android:id="@+id/inputDialogPaste"
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:gravity="top|start"
                            android:hint="Type or Paste here your exported prices thru Presyohan..."
                            android:inputType="textMultiLine|textCapSentences"
                            android:padding="12dp"
                            android:textSize="13sp"
                            android:background="@drawable/bg_edittext"
                            android:textColor="@color/presyo_darkblue"
                            android:textColorHint="@color/edittext_hint" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Next Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/button_round"
                    android:backgroundTint="@color/presyo_orange"
                    android:text="NEXT"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

</LinearLayout>

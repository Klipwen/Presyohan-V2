<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_custom"
    android:gravity="center_horizontal"
    android:minWidth="340dp">

    <!-- Title: Invite Staff -->
    <TextView
        android:id="@+id/inviteStaffTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Invite Staff"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/presyo_orange"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp" />

    <!-- Icon Container: Rounded light grey container with orange person+ icon -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:background="@drawable/bg_rounded_grey"
        android:layout_marginBottom="12dp"
        android:padding="16dp">

        <ImageView
            android:id="@+id/inviteStaffIcon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:src="@drawable/icon_invite_staff"
            app:tint="@color/presyo_orange" />

    </FrameLayout>

    <!-- SECTION 1: DIRECT INVITATION -->
    <LinearLayout
        android:id="@+id/layoutDirectInvitation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Trigger to Join Store Code -->
        <TextView
            android:id="@+id/btnSwitchToCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join Store Code >"
            android:textColor="@color/presyo_orange"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_gravity="end"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- User ID TextInputLayout -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutSearchInput"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxStrokeColor="@color/stroke_orange"
            app:hintTextColor="@color/presyo_orange"
            android:textColorHint="@color/presyo_orange"
            app:expandedHintEnabled="false"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/searchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="User ID"
                android:inputType="textEmailAddress"
                android:textColor="@color/presyo_darkblue"
                android:textSize="15sp"
                android:paddingVertical="10dp"
                android:paddingHorizontal="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Loader / NotFound / UserResult States -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ProgressBar
                android:id="@+id/searchLoader"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:indeterminateTint="@color/presyo_orange"/>

            <TextView
                android:id="@+id/textNotFound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No user found with this ID or Email."
                android:textColor="@color/edittext_hint"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/userResultContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFBE6"
                android:padding="8dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/foundUserAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/icon_profile"
                    android:scaleType="centerCrop"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/foundUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Name"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/foundUserDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="code • email"
                        android:textColor="#666666"
                        android:textSize="11sp"
                        android:ellipsize="end"
                        android:maxLines="1"/>
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>

        <!-- Staff Role TextInputLayout -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutRoleSpinner"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxStrokeColor="@color/stroke_teal"
            app:hintTextColor="@color/presyo_teal"
            android:textColorHint="@color/presyo_teal"
            app:expandedHintEnabled="false"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            android:layout_marginBottom="16dp">

            <AutoCompleteTextView
                android:id="@+id/spinnerRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Staff Role"
                android:inputType="none"
                android:textColor="@color/presyo_teal"
                android:textSize="15sp"
                android:paddingVertical="10dp"
                android:paddingHorizontal="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Direct Invite Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/button_round"
                android:backgroundTint="@color/presyo_teal"
                android:text="BACK"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnInvite"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/button_round"
                android:backgroundTint="@color/presyo_orange"
                android:text="INVITE"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/inviteErrorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_gravity="center"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- SECTION 2: JOIN STORE CODE -->
    <LinearLayout
        android:id="@+id/layoutJoinStoreCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Label with Info Icon -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join store code"
                android:textColor="#888888"
                android:textSize="13sp" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/icon_info"
                app:tint="#888888"
                android:contentDescription="Info" />

        </LinearLayout>

        <!-- CODE GENERATE ROW (INACTIVE STATE) -->
        <LinearLayout
            android:id="@+id/layoutCodeInactive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <!-- Dashed Placeholder Box -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_code_box_border">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="------"
                    android:textColor="#FB8500"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

            </FrameLayout>

            <!-- Generate Button (Rectangular, not fully rounded/oval) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGenerateCodeInactive"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_button_rect_teal"
                android:text="Generate"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:paddingHorizontal="34dp"/>

        </LinearLayout>

        <!-- CODE GENERATE ROW (ACTIVE STATE) -->
        <LinearLayout
            android:id="@+id/layoutCodeActive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <!-- Active Code Box -->
            <RelativeLayout
                android:id="@+id/btnCopyCodeActive"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_code_box_border"
                android:paddingHorizontal="12dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true">

                    <TextView
                        android:id="@+id/storeCodeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="758201"
                        android:textColor="#FB8500"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="0dp"/>

                    <TextView
                        android:id="@+id/inviteCodeExpiry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Valid only in --:--:--"
                        android:textColor="#FB8500"
                        android:textSize="12sp"
                        android:includeFontPadding="false"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/icon_copy"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:tint="#FB8500" />

            </RelativeLayout>

            <!-- Active Action Buttons (Stacked Vertically) -->
            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="50dp"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <!-- Generate New Button (Rectangular, not fully rounded/oval) -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnGenerateCodeActive"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_button_rect_teal"
                    android:text="Generate new"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textAllCaps="false"
                    android:paddingHorizontal="4dp"
                    android:layout_marginBottom="2dp"
                    android:layout_marginTop="2dp"/>

                <!-- Revoke Button (Rectangular with teal outline, not fully rounded) -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRevokeCodeActive"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_button_rect_outline_teal"
                    android:text="Revoke"
                    android:textColor="@color/presyo_teal"
                    android:textSize="10sp"
                    android:textAllCaps="false"
                    android:paddingHorizontal="4dp"
                    android:layout_marginBottom="2dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Trigger to switch back to Direct Invitation -->
        <TextView
            android:id="@+id/btnSwitchToDirect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt; Direct Invitation"
            android:textColor="@color/presyo_orange"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_gravity="start"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- DONE Button (Oval/rounded corner) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/button_round"
            android:backgroundTint="@color/presyo_orange"
            android:text="DONE"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_rounded"
    android:gravity="start">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notes Preview"
        android:textColor="@color/presyo_orange"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Scrollable Text Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/bg_edittext"
        android:padding="12dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/textNotesPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/presyo_darkblue"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:text="Preview notes will load here..." />
    </ScrollView>

    <!-- Dialog Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Close"
            android:textColor="@color/edittext_hint"
            android:background="@drawable/button_round"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCopyToClipboard"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Copy"
            android:textColor="@color/white"
            android:backgroundTint="@color/presyo_teal"
            android:background="@drawable/button_round"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnShare"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Share"
            android:textColor="@color/white"
            android:backgroundTint="@color/presyo_orange"
            android:background="@drawable/button_round"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

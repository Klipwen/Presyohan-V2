<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_custom"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Title: Store Details -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Store Details"
        android:textColor="@color/presyo_orange"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Store Summary Card (Horizontal Layout) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded_grey"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <!-- Store Icon -->
        <ImageView
            android:id="@+id/dialogStoreIcon"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/icon_store"
            android:layout_marginEnd="16dp"
            android:contentDescription="Store Logo"/>

        <!-- Store Details Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Store Name -->
            <TextView
                android:id="@+id/dialogStoreName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Store Name"
                android:textColor="@color/presyo_orange"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Store Category -->
            <TextView
                android:id="@+id/dialogStoreCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Store Category"
                android:textColor="@color/presyo_teal"
                android:textSize="14sp"/>

            <!-- Branch / Location -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_location"
                    app:tint="#888888"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/dialogStoreBranch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Branch Location"
                    android:textColor="#888888"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Quick Actions Row (Convert Prices, Add Staff, QR Code, Settings) -->
    <LinearLayout
        android:id="@+id/dialogQuickActionsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <!-- Convert Prices -->
        <LinearLayout
            android:id="@+id/layoutConvert"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/icon_convert"
                app:tint="@color/presyo_teal" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Convert"
                android:textColor="@color/presyo_teal"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Add Staff -->
        <LinearLayout
            android:id="@+id/layoutInvite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/icon_invite_staff"
                app:tint="@color/presyo_teal" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Staff"
                android:textColor="@color/presyo_teal"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:gravity="center" />
        </LinearLayout>

        <!-- QR Code -->
        <LinearLayout
            android:id="@+id/layoutQRCode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/icon_qr_code"
                app:tint="@color/presyo_teal" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QR Code"
                android:textColor="@color/presyo_teal"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/layoutSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/icon_settings"
                app:tint="@color/presyo_teal" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="@color/presyo_teal"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:gravity="center" />
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/dialogOwnerDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#D9D9D9"
        android:layout_marginBottom="16dp" />

    <!-- Role designation text -->
    <TextView
        android:id="@+id/textRoleDesignation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You are the Owner of this store."
        android:textColor="#555555"
        android:textSize="14sp"
        android:gravity="start"
        android:layout_marginBottom="20dp" />

    <!-- Stats Frame Layout containing Shimmer and Actual Stats -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <!-- Shimmer Skeleton Loading -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/dialogShimmerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Two-column mock layout for skeleton -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Left Column -->
                <TableLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.25"
                    android:stretchColumns="1"
                    android:layout_marginEnd="4dp">

                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="60dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="70dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>
                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="70dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="50dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>
                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="55dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="60dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>
                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="80dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="40dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>
                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="65dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="30dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>
                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="45dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="35dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>

                </TableLayout>

                <!-- Right Column -->
                <TableLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.75"
                    android:stretchColumns="1"
                    android:layout_marginStart="4dp">

                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="60dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="30dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>
                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="70dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="20dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>
                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="80dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="20dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>
                    <TableRow android:layout_marginBottom="12dp">
                        <View android:layout_width="75dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="20dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>
                    <TableRow android:layout_marginBottom="8dp">
                        <View android:layout_width="50dp" android:layout_height="14dp" android:background="#E8E8E8" />
                        <View android:layout_width="30dp" android:layout_height="14dp" android:layout_gravity="end" android:background="#E8E8E8" />
                    </TableRow>

                </TableLayout>

            </LinearLayout>

        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- Actual Stats Layout -->
        <LinearLayout
            android:id="@+id/dialogStatsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- Left Column -->
            <TableLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.25"
                android:stretchColumns="1"
                android:layout_marginEnd="4dp">

                <!-- Store ID -->
                <TableRow android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Store ID"
                        android:textColor="#555555"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/dialogStoreId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SID25-009"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:gravity="end" />
                </TableRow>

                <!-- Created at -->
                <TableRow android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Created at:"
                        android:textColor="#555555"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/dialogCreatedAt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="04/07/24"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:gravity="end" />
                </TableRow>

                <!-- Status -->
                <TableRow android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status:"
                        android:textColor="#555555"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/dialogVisibilityStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Public"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:gravity="end" />
                </TableRow>

                <!-- Join Store Code -->
                <TableRow android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Join code:"
                        android:textColor="#555555"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/dialogJoinCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expired"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:gravity="end" />
                </TableRow>

                <!-- Categories -->
                <TableRow android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Categories:"
                        android:textColor="#555555"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/dialogCategoriesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="16"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:gravity="end" />
                </TableRow>

                <!-- Items -->
                <TableRow android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Items:"
                        android:textColor="#555555"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/dialogItemsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="106"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:gravity="end" />
                </TableRow>

            </TableLayout>

            <!-- Right Column -->
            <TableLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.75"
                android:stretchColumns="1"
                android:layout_marginStart="4dp">

                <!-- Members Label -->
                <TableRow android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/icon_people"
                            app:tint="#555555"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="members:"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/dialogMembersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="end" />
                </TableRow>

                <!-- Owners -->
                <TableRow android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  • Owners:"
                        android:textColor="#777777"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/dialogOwnersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textColor="#777777"
                        android:textSize="13sp"
                        android:gravity="end" />
                </TableRow>

                <!-- Managers -->
                <TableRow android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  • Managers:"
                        android:textColor="#777777"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/dialogManagersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textColor="#777777"
                        android:textSize="13sp"
                        android:gravity="end" />
                </TableRow>

                <!-- Sales Staff -->
                <TableRow android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  • Staff:"
                        android:textColor="#777777"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/dialogEmployeesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6"
                        android:textColor="#777777"
                        android:textSize="13sp"
                        android:gravity="end" />
                </TableRow>

                <!-- Suki Label -->
                <TableRow android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/icon_people"
                            app:tint="#555555"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Suki"
                            android:textColor="#555555"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/dialogSukiCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="21"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="end" />
                </TableRow>

            </TableLayout>

        </LinearLayout>
    </FrameLayout>

    <!-- Buttons Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- DONE Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/button_round"
            android:backgroundTint="@color/presyo_orange"
            android:text="DONE"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>

</LinearLayout>

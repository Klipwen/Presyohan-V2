<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_custom"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="20dp">

    <!-- Store Icon -->
    <ImageView
        android:id="@+id/dialogStoreIcon"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:src="@drawable/icon_store"
        android:layout_marginEnd="12dp"
        android:contentDescription="Store Logo"/>

    <!-- Store Details Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Store Name -->
        <TextView
            android:id="@+id/dialogStoreName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Store Name"
            android:textColor="@color/presyo_orange"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Store Category -->
        <TextView
            android:id="@+id/dialogStoreCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Store Category"
            android:textColor="@color/presyo_teal"
            android:textSize="12sp"/>

        <!-- Branch / Location -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_location"
                app:tint="#888888"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/dialogStoreBranch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Branch Location"
                android:textColor="#888888"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Quick Action Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="8dp">

        <!-- Add Staff Button -->
        <ImageView
            android:id="@+id/layoutInvite"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/icon_invite_staff"
            app:tint="@color/presyo_teal"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Invite Members"
            android:layout_marginEnd="16dp"/>

        <!-- Settings Button -->
        <ImageView
            android:id="@+id/layoutSettings"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/icon_settings"
            app:tint="@color/presyo_teal"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Store Settings"/>

    </LinearLayout>

</LinearLayout>

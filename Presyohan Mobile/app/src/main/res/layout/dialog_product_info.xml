<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_custom"
    android:minWidth="320dp">

    <!-- Dialog Header Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Product Information"
        android:textColor="@color/presyo_orange"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- Details Card Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_unselected"
        android:padding="16dp"
        android:layout_marginBottom="20dp">

        <!-- Product Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textColor="@color/presyo_teal"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textInfoName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Product Name"
            android:textColor="@color/presyo_darkblue"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Product Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/presyo_teal"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textInfoDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Product Description"
            android:textColor="@color/presyo_darkblue"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <!-- Price and Unit Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price"
                    android:textColor="@color/presyo_teal"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/textInfoPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₱ 0.00"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unit"
                    android:textColor="@color/presyo_teal"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/textInfoUnit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="pcs"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Visibility -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Visibility"
            android:textColor="@color/presyo_teal"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textInfoVisibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Public"
            android:textColor="@color/presyo_teal"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Close Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/button_round_teal"
        android:text="CLOSE"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"/>

</LinearLayout>

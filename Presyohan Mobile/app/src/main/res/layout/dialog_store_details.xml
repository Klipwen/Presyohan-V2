<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Store Details"
            android:textColor="@color/presyo_orange"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/icon_store"
                android:contentDescription="Store Logo"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/dialogStoreName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QSOS"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dialogStoreBranch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Curva branch"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Subheader role designation -->
        <TextView
            android:id="@+id/textRoleDesignation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You are the Manager of this store."
            android:textColor="#E65100"
            android:textSize="13sp"
            android:textStyle="italic"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp" />

        <!-- Metadata Section (Left column key, right column value) -->
        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1">

            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Store ID:"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:paddingEnd="16dp"/>
                <TextView
                    android:id="@+id/dialogStoreId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="S6E6-000"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </TableRow>

            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Created at:"
                    android:textColor="#555555"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialogCreatedAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="04/10/24"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="13sp" />
            </TableRow>

            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status:"
                    android:textColor="#555555"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialogVisibilityStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Public"
                    android:textColor="@color/presyo_teal"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </TableRow>

            <TableRow android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join Store code:"
                    android:textColor="#555555"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialogJoinCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expired"
                    android:textColor="#D32F2F"
                    android:textSize="13sp" />
            </TableRow>

            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Categories:"
                    android:textColor="#555555"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialogCategoriesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </TableRow>

            <TableRow android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Items:"
                    android:textColor="#555555"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialogItemsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </TableRow>

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Members:"
                    android:textColor="#555555"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/dialogMembersCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textColor="@color/presyo_darkblue"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </TableRow>

        </TableLayout>

        <!-- Bullet lists for members roles counts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/dialogOwnersCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Owners: 1"
                android:textColor="#777777"
                android:textSize="12sp"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/dialogManagersCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Managers: 3"
                android:textColor="#777777"
                android:textSize="12sp"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/dialogEmployeesCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Sales staff: 8"
                android:textColor="#777777"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Bottom Actions Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- LEAVE Store Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLeaveStore"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/button_outline_dialog"
                android:text="LEAVE"
                android:textColor="@color/red"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- BACK Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/button_round"
                android:backgroundTint="@color/presyo_orange"
                android:text="BACK"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

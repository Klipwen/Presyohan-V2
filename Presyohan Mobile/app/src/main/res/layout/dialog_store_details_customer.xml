<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_custom"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Title: Store Details -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Store Details"
        android:textColor="@color/presyo_orange"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Store Summary Card (Horizontal Layout) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded_grey"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <!-- Store Icon -->
        <ImageView
            android:id="@+id/dialogStoreIcon"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/icon_store"
            android:layout_marginEnd="16dp"
            android:contentDescription="Store Logo"/>

        <!-- Store Details Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Store Name -->
            <TextView
                android:id="@+id/dialogStoreName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Store Name"
                android:textColor="@color/presyo_orange"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Store Category -->
            <TextView
                android:id="@+id/dialogStoreCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Store Category"
                android:textColor="@color/presyo_teal"
                android:textSize="14sp"/>

            <!-- Branch / Location -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_location"
                    app:tint="#888888"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/dialogStoreBranch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Branch Location"
                    android:textColor="#888888"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Stats Frame Layout containing Shimmer and Actual Table -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <!-- Shimmer Skeleton Loading -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/dialogShimmerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1"
                android:paddingHorizontal="8dp">

                <TableRow android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="80dp"
                        android:layout_height="16dp"
                        android:background="#E8E8E8" />
                    <View
                        android:layout_width="80dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end"
                        android:background="#E8E8E8" />
                </TableRow>

                <TableRow android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="70dp"
                        android:layout_height="16dp"
                        android:background="#E8E8E8" />
                    <View
                        android:layout_width="90dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end"
                        android:background="#E8E8E8" />
                </TableRow>

                <TableRow android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="90dp"
                        android:layout_height="16dp"
                        android:background="#E8E8E8" />
                    <View
                        android:layout_width="75dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end"
                        android:background="#E8E8E8" />
                </TableRow>

                <TableRow android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="100dp"
                        android:layout_height="16dp"
                        android:background="#E8E8E8" />
                    <View
                        android:layout_width="40dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end"
                        android:background="#E8E8E8" />
                </TableRow>

                <TableRow android:layout_marginBottom="12dp">
                    <View
                        android:layout_width="60dp"
                        android:layout_height="16dp"
                        android:background="#E8E8E8" />
                    <View
                        android:layout_width="50dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end"
                        android:background="#E8E8E8" />
                </TableRow>

                <TableRow android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="110dp"
                        android:layout_height="16dp"
                        android:background="#E8E8E8" />
                    <View
                        android:layout_width="35dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end"
                        android:background="#E8E8E8" />
                </TableRow>

            </TableLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- Actual Table Layout -->
        <TableLayout
            android:id="@+id/dialogStatsTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1"
            android:paddingHorizontal="8dp"
            android:visibility="gone">

            <!-- Store ID -->
            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Store ID"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/dialogStoreId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="----"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:gravity="end" />
            </TableRow>

            <!-- Status -->
            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status:"
                    android:textColor="#555555"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/dialogVisibilityStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="----"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:gravity="end" />
            </TableRow>

            <!-- Created at -->
            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Created at:"
                    android:textColor="#555555"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/dialogCreatedAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-----"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:gravity="end" />
            </TableRow>

            <!-- Categories -->
            <TableRow android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Categories:"
                    android:textColor="#555555"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/dialogCategoriesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="----"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:gravity="end" />
            </TableRow>

            <!-- Items -->
            <TableRow android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Items:"
                    android:textColor="#555555"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/dialogItemsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="----"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:gravity="end" />
            </TableRow>

            <!-- Suki -->
            <TableRow android:layout_marginBottom="8dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/icon_people"
                        app:tint="#555555"
                        android:layout_marginEnd="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Suki"
                        android:textColor="#555555"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/dialogSukiCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="----"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="end" />
            </TableRow>

        </TableLayout>
    </FrameLayout>

    <!-- BACK Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/button_round"
        android:backgroundTint="@color/presyo_orange"
        android:text="BACK"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="16sp" />

</LinearLayout>

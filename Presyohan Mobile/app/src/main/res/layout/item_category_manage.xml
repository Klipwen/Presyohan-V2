<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingBottom="6dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_unselected"
        android:padding="16dp">

        <!-- Row 1: Title, Subtitle, Copy, Convert Actions -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Left Column: Name & Count -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/layoutRightActions"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/textCategoryName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category Name"
                    android:textColor="@color/presyo_teal"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/textItemCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 items"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Right Column: Copy & Convert buttons -->
            <LinearLayout
                android:id="@+id/layoutRightActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <!-- Copy Button -->
                <LinearLayout
                    android:id="@+id/btnCopyCategory"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_copy_prices"
                        app:tint="@color/presyo_orange"
                        android:contentDescription="Copy" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Copy"
                        android:textColor="@color/presyo_orange"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Convert Button -->
                <LinearLayout
                    android:id="@+id/btnConvertCategory"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:layout_marginStart="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/icon_convert"
                        app:tint="@color/presyo_orange"
                        android:contentDescription="Convert" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Convert"
                        android:textColor="@color/presyo_orange"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>

        <!-- Row 2: Make it Public Switch -->
        <LinearLayout
            android:id="@+id/layoutPublicContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/checkboxPublic"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_radio_unchecked"
                android:contentDescription="Make it Public" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Make it Public"
                android:textColor="#555555"
                android:textSize="13sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Row 3: Action Buttons at the Bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="3">

            <TextView
                android:id="@+id/btnViewItems"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_outline_button_teal"
                android:gravity="center"
                android:text="View Items"
                android:textColor="@color/presyo_teal"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btnRename"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_outline_button_orange"
                android:gravity="center"
                android:text="Rename"
                android:textColor="@color/presyo_orange"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_solid_button_orange"
                android:gravity="center"
                android:text="Delete"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Category Tag Header (grey text, top left) -->
        <TextView
            android:id="@+id/tvCategoryLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="#888888"
            android:textSize="10sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Folder Icon Container (left of details) -->
        <FrameLayout
            android:id="@+id/folderIconContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_rounded_store_icon"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryLabel"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/icon_category1" />
        </FrameLayout>

        <!-- Category Name -->
        <TextView
            android:id="@+id/tvCategoryName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="SCHOOL SUPPLIES"
            android:textColor="@color/presyo_orange"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/folderIconContainer"
            app:layout_constraintStart_toEndOf="@id/folderIconContainer"
            app:layout_constraintEnd_toStartOf="@id/tvCategoryItemCount"
            android:layout_marginEnd="16dp" />

        <!-- Store Name -->
        <TextView
            android:id="@+id/tvCategoryStoreName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Marie's store"
            android:textColor="@color/presyo_teal"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryName"
            app:layout_constraintStart_toStartOf="@id/tvCategoryName"
            app:layout_constraintEnd_toStartOf="@id/tvCategoryItemCount"
            android:layout_marginEnd="16dp" />

        <!-- Pin Icon and Location -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryStoreName"
            app:layout_constraintStart_toStartOf="@id/tvCategoryName"
            app:layout_constraintEnd_toStartOf="@id/tvCategoryItemCount"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_location"
                app:tint="#888888" />

            <TextView
                android:id="@+id/tvCategoryLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Curva Medellin, Cebu"
                android:textColor="#888888"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Item Count (Bottom right) -->
        <TextView
            android:id="@+id/tvCategoryItemCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="211 Items"
            android:textColor="@color/presyo_teal"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

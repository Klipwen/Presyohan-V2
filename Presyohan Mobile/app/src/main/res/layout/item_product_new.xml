<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp">

    <RelativeLayout
        android:id="@+id/layoutNormal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/layoutRightInfo"
            android:layout_marginEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/textProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bottle water"
                    android:textColor="@color/presyo_orange"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imagePublicIndicator"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="Public Indicator"
                    android:src="@drawable/icon_public_indacator"
                    android:visibility="visible" />
            </LinearLayout>

            <TextView
                android:id="@+id/textProductDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#888888"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutRightInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_alignParentEnd="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/textProductPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱15.00"
                    android:textColor="@color/presyo_teal"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/textProductVolume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500 ml"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </RelativeLayout>

    <FrameLayout
        android:id="@+id/layoutOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_selected_product_overlay"
        android:visibility="gone">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="10dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/layoutOverlayActions"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/overlayProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bottle water"
                    android:textColor="@color/presyo_orange"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/overlayProductDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/overlayProductPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱15.00"
                        android:textColor="@color/presyo_teal"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/overlayProductVolume"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500 ml"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutOverlayActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <ImageView
                    android:id="@+id/btnEditProduct"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/icon_edit"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Edit"
                    app:tint="@color/presyo_teal"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:id="@+id/btnDeleteProduct"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/icon_delete"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Delete"
                    app:tint="@color/presyo_teal"/>

            </LinearLayout>

        </RelativeLayout>
    </FrameLayout>

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="12dp"
    android:paddingHorizontal="4dp"
    android:background="@android:color/transparent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Left Content: Name (with badge inline) and Description -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/layoutPriceArea"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/itemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itemDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ari ang descriptions ibutang"
                android:textColor="@color/edittext_hint"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Right Content: Price & Unit -->
        <LinearLayout
            android:id="@+id/layoutPriceArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/itemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱ 132.50"
                android:textColor="@color/presyo_teal"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itemUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Kilo"
                android:textColor="@color/edittext_hint"
                android:textSize="12sp" />

        </LinearLayout>

    </RelativeLayout>

    <!-- Validation Error Text under the row if invalid -->
    <TextView
        android:id="@+id/tvErrorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Error message description goes here"
        android:textColor="#FB8500"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Divider Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EAEAEA"
        android:layout_marginTop="12dp" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Background Action Layout (hidden under foreground card by default) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/backgroundActionCard"
        android:layout_width="120dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="6dp"
        app:cardBackgroundColor="#F0F4F8"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:layout_constraintBottom_toBottomOf="@id/foregroundCardView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/foregroundCardView">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Action Button 1 (Settings / View) -->
            <FrameLayout
                android:id="@+id/btnAction1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/imageAction1"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="Primary Action"
                    android:src="@drawable/icon_settings"
                    app:tint="@color/presyo_teal" />
            </FrameLayout>

            <!-- Action Button 2 (Delete / Leave) -->
            <FrameLayout
                android:id="@+id/btnAction2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/imageAction2"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="Secondary Action"
                    android:src="@drawable/icon_delete"
                    app:tint="@color/presyo_teal" />
            </FrameLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Foreground Card Layout (slides to reveal actions) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/foregroundCardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="3dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- Store Icon Frame Container -->
            <FrameLayout
                android:id="@+id/storeIconFrame"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_store_icon_other"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/imageStoreIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="Store Icon"
                    android:src="@drawable/icon_store" />
            </FrameLayout>

            <!-- Store Name -->
            <TextView
                android:id="@+id/textStoreName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Store Name"
                android:textColor="@color/presyo_orange"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/staffCountBadge"
                app:layout_constraintStart_toEndOf="@id/storeIconFrame"
                app:layout_constraintTop_toTopOf="@id/storeIconFrame" />

            <!-- Store Type -->
            <TextView
                android:id="@+id/textStoreType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="General Merchandise"
                android:textColor="@color/presyo_teal"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/staffCountBadge"
                app:layout_constraintStart_toStartOf="@id/textStoreName"
                app:layout_constraintTop_toBottomOf="@id/textStoreName" />

            <!-- Location Branch Row -->
            <LinearLayout
                android:id="@+id/branchRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/textStoreName"
                app:layout_constraintTop_toBottomOf="@id/textStoreType">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:contentDescription="Location Pin"
                    android:src="@drawable/ic_location"
                    app:tint="@color/edittext_hint" />

                <TextView
                    android:id="@+id/textStoreBranch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Curva branch"
                    android:textColor="@color/edittext_hint"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Staff Count Badge (Top-Right) -->
            <LinearLayout
                android:id="@+id/staffCountBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/textStoreName">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="Member Icon"
                    android:src="@drawable/icon_people"
                    app:tint="@color/edittext_hint" />

                <TextView
                    android:id="@+id/textMemberCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="12"
                    android:textColor="@color/edittext_hint"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Role Indicator (Bottom-Right) -->
            <TextView
                android:id="@+id/textStoreRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="Role: Owner"
                android:textColor="@color/edittext_hint"
                android:textSize="11sp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@id/branchRow"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
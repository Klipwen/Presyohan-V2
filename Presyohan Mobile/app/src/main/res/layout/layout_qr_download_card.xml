<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1200px"
    android:layout_height="1600px"
    android:background="#FFB703"
    android:padding="60px">

    <!-- Inner Card with Custom Rounded Shape -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.CustomCard"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Top Header Logo Section -->
            <LinearLayout
                android:id="@+id/layoutLogoContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="80px"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Logo icon -->
                <ImageView
                    android:layout_width="100px"
                    android:layout_height="100px"
                    android:src="@drawable/icon_presyohan"
                    android:rotation="-45"
                    android:contentDescription="Presyohan Icon" />

                <!-- Logo Text with 'atong' stacked and 'presyohan?' -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="20px">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="atong"
                        android:textColor="#FB8500"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="0dp" />

                    <!-- Horizontal container for presyohan? -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="-10px">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="presyo"
                            android:textColor="#FB8500"
                            android:textSize="58sp"
                            android:textStyle="bold"
                            android:includeFontPadding="false" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="han?"
                            android:textColor="#219EBC"
                            android:textSize="58sp"
                            android:textStyle="bold"
                            android:includeFontPadding="false" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Center QR Code Image -->
            <ImageView
                android:id="@+id/ivDownloadQr"
                android:layout_width="720px"
                android:layout_height="720px"
                android:scaleType="fitCenter"
                android:contentDescription="Store QR Code"
                app:layout_constraintTop_toBottomOf="@id/layoutLogoContainer"
                app:layout_constraintBottom_toTopOf="@id/layoutStoreInfo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Bottom Store Info Section (Cream Box) -->
            <LinearLayout
                android:id="@+id/layoutStoreInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFF9E9"
                android:paddingVertical="70px"
                android:paddingHorizontal="40px"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Store Name -->
                <TextView
                    android:id="@+id/tvDownloadStoreName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QSOS"
                    android:textColor="#FB8500"
                    android:textSize="52sp"
                    android:textStyle="bold" />

                <!-- Store ID -->
                <TextView
                    android:id="@+id/tvDownloadStoreId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Store ID: SID25-0009"
                    android:textColor="#FB8500"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16px" />

                <!-- Location -->
                <TextView
                    android:id="@+id/tvDownloadStoreLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Curva Medellin, Cebu"
                    android:textColor="#FB8500"
                    android:textSize="26sp"
                    android:layout_marginTop="12px" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
